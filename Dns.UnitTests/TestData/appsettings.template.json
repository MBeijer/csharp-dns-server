{
  "server": {
    "zones": [
      {
        "name": "{{ZONE_SUFFIX}}",
        "provider": "Dns.ZoneProvider.AP.APZoneProvider",
        "providerSettings": {
          "$type": "filewatcher",
          "fileName": "{{ZONE_FILE}}"
        }
      }
    ],
    "dnsListener": {
      "port": {{DNS_PORT}},
      "tcpPort": {{DNS_PORT}}
    },
    "zoneTransfer": {
      "enabled": true,
      "allowTransfersFrom": [
        "127.0.0.1/32"
      ],
      "notifySecondaries": [],
      "notifyPollIntervalSeconds": 1
    },
    "webServer": {
      "JwtSecretKey": "a86d8487a8712b944eecc64f27334822a0666ef2db901ffd17ec75ebe732732b"
    }
  },
  "databaseSettings": {
    "sqliteDefault": "Data Source=dns.db"
  }
}
